# ============================================================================
#  VTuber My Avatar - .gitignore
#
#  This repo ships ONLY the kit's own code (Python tracker + C# driver scripts).
#  It intentionally contains no avatar, outfit, shader, or built .exe - those
#  are licensed third-party assets that cannot be redistributed.
#
#  The rules below keep it that way: if you drop this kit into a real Unity
#  project (or generate caches by opening it), none of that licensed content
#  or machine-local junk can be committed by accident.
# ============================================================================

# ---- NEVER publish: licensed avatar content & the built player -------------
# (Assets/ whitelist - ignore everything under any Assets/ except the kit)
Assets/*
!Assets/vTuber/
!Assets/vTuber.meta
**/Assets/*
!**/Assets/vTuber/
!**/Assets/vTuber.meta
**/Export/
**/*.unitypackage
/Build/
**/vtuber_config.json

# ---- Python tracker: regenerated by setup_tracker.bat ----------------------
Tracker/.venv/
Tracker/models/
**/__pycache__/
*.pyc

# ---- Unity generated caches & user-local files -----------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Ll]ogs/
[Uu]serSettings/
[Bb]uild/
[Mm]emoryCaptures/
.vs/

# Unity-generated solution/project files (recreated on open)
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.pdb
*.mdb
*.opendb
*.VC.db

# ---- AI assistant scaffolding (local only, not part of the kit) ------------
CLAUDE.md
.claude/

# ---- OS / editor noise -----------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
